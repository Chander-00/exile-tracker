# === Server ===
PORT=:3000

# === Database ===
# In Docker, this should point inside the mounted volume
DB_PATH=/app/data/data.db

# === SSH TUI ===
SSH_PORT=:2222
# SSH host key is auto-generated by the wish library at this path.
# In Docker, the .ssh/ directory is mounted as a volume for persistence.
SSH_HOST_KEY_PATH=.ssh/exile_tracker_ed25519
# Your SSH public key (authorized_keys format) for admin access to the TUI
SSH_ADMIN_KEY=

# === Path of Building ===
# In Docker, PoB is cloned to /app/PathOfBuilding during image build
POB_ROOT=/app/PathOfBuilding
# Leave empty to auto-detect luajit from PATH (installed in Docker image)
LUAJIT_PATH=

# === PoE API ===
# Base URL for the Path of Exile API (the fetcher uses this)
POE_API_BASE_URL=https://www.pathofexile.com
# How often (in minutes) the fetcher checks for character updates
FETCH_INTERVAL_IN_MINUTES=30

# === API ===
# Secret key for authenticating API requests
API_KEY=change-me-to-a-real-secret
